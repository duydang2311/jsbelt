{
    "name": "@duydang2311/jsbelt",
    "type": "module",
    "version": "0.0.5",
    "description": "JavaScript/TypeScript handy utilities in the belt. Available to grab whenever you need.",
    "author": "Dang Quoc Duy <duyda.himself@gmail.com>",
    "license": "MIT",
    "homepage": "https://github.com/duydang2311/jsbelt#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/duydang2311/jsbelt.git"
    },
    "bugs": {
        "url": "https://github.com/duydang2311/jsbelt/issues"
    },
    "exports": {
        ".": "./dist/index.mjs",
        "./vite": "./dist/vite.mjs",
        "./package.json": "./package.json"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "test": "vitest",
        "typecheck": "tsc --noEmit",
        "release": "bumpp",
        "prepublishOnly": "bun run build"
    },
    "devDependencies": {
        "@types/node": "^18",
        "@typescript/native-preview": "7.0.0-dev.20260509.2",
        "bumpp": "^11.1.0",
        "nanoevents": "^9.1.0",
        "tsdown": "^0.22.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.14",
        "vitest": "^4.1.7"
    },
    "peerDependencies": {
        "vite": "^8.0.0"
    },
    "inlinedDependencies": {
        "nanoevents": "9.1.0"
    },
    "sideEffects": false,
    "engines": {
        "node": ">=18"
    },
    "dependencies": {
        "magic-string": "^0.30.21",
        "oxc-parser": "^0.132.0"
    }
